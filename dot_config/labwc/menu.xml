<?xml version="1.0" encoding="UTF-8"?>
<openbox_menu>
<menu id="root-menu" label="root-menu">
  <menu id="Accessories" label="Accessories">
    <item label="PCManFM-Qt File Manager">
      <action name="Execute"><command>pcmanfm-qt</command></action>
    </item>
    <item label="Vim">
      <action name="Execute"><command>vim</command></action>
    </item>
    <item label="xgps">
      <action name="Execute"><command>xgps</command></action>
    </item>
    <item label="xgpsspeed">
      <action name="Execute"><command>xgpsspeed</command></action>
    </item>
  </menu> <!-- Accessories -->
  <menu id="Development" label="Development">
    <item label="CMake">
      <action name="Execute"><command>cmake-gui</command></action>
    </item>
    <item label="Code - OSS">
      <action name="Execute"><command>code-oss</command></action>
    </item>
    <item label="Qt Assistant">
      <action name="Execute"><command>assistant6</command></action>
    </item>
    <item label="Qt D-Bus Viewer">
      <action name="Execute"><command>qdbusviewer6</command></action>
    </item>
    <item label="Qt Linguist">
      <action name="Execute"><command>linguist6</command></action>
    </item>
    <item label="Qt Widgets Designer">
      <action name="Execute"><command>designer6</command></action>
    </item>
  </menu> <!-- Development -->
  <menu id="Internet" label="Internet">
    <item label="Avahi SSH Server Browser">
      <action name="Execute"><command>/usr/bin/bssh</command></action>
    </item>
    <item label="Avahi VNC Server Browser">
      <action name="Execute"><command>/usr/bin/bvnc</command></action>
    </item>
    <item label="Firefox">
      <action name="Execute"><command>/usr/lib/firefox/firefox</command></action>
    </item>
    <item label="Thunderbird">
      <action name="Execute"><command>thunderbird</command></action>
    </item>
  </menu> <!-- Internet -->
  <menu id="Multimedia" label="Multimedia">
    <item label="Qt V4L2 test Utility">
      <action name="Execute"><command>qv4l2</command></action>
    </item>
    <item label="Qt V4L2 video capture utility">
      <action name="Execute"><command>qvidcap</command></action>
    </item>
  </menu> <!-- Multimedia -->
  <menu id="Settings" label="Settings">
    <item label="Desktop">
      <action name="Execute"><command>pcmanfm-qt --desktop-pref=general</command></action>
    </item>
    <item label="Labwc Tweaks">
      <action name="Execute"><command>labwc-tweaks</command></action>
    </item>
    <item label="Manage Printing">
      <action name="Execute"><command>xdg-open http://localhost:631/</command></action>
    </item>
    <item label="Print Settings">
      <action name="Execute"><command>system-config-printer</command></action>
    </item>
  </menu> <!-- Settings -->
  <menu id="System" label="System">
    <item label="Avahi Zeroconf Browser">
      <action name="Execute"><command>/usr/bin/avahi-discover</command></action>
    </item>
    <item label="btop++">
      <action name="Execute"><command>btop</command></action>
    </item>
    <item label="Foot">
      <action name="Execute"><command>foot</command></action>
    </item>
    <item label="Foot Client">
      <action name="Execute"><command>footclient</command></action>
    </item>
    <item label="Foot Server">
      <action name="Execute"><command>foot --server</command></action>
    </item>
    <item label="Manage Printing">
      <action name="Execute"><command>xdg-open http://localhost:631/</command></action>
    </item>
    <item label="Print Settings">
      <action name="Execute"><command>system-config-printer</command></action>
    </item>
  </menu> <!-- System -->
  <menu id="Other" label="Other">
    <item label="Rofi">
      <action name="Execute"><command>rofi -show</command></action>
    </item>
    <item label="Rofi Theme Selector">
      <action name="Execute"><command>rofi-theme-selector</command></action>
    </item>
  </menu> <!-- Other -->
</menu> <!-- root-menu -->
</openbox_menu>
